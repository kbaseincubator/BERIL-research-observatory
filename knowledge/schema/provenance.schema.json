{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/beril/provenance.schema.json",
  "title": "BERIL Project Provenance Schema",
  "description": "Structured provenance metadata for BERIL Observatory projects.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "references",
    "data_sources",
    "cross_project_deps",
    "findings",
    "generated_data"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      }
    },
    "data_sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/data_source"
      }
    },
    "cross_project_deps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/cross_project_dep"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "generated_data": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/generated_data_entry"
      }
    }
  },
  "$defs": {
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "title"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "primary_data_source",
            "supporting",
            "contradicting",
            "methodology",
            "review"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "authors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "year": {
          "type": [
            "integer",
            "null"
          ]
        },
        "journal": {
          "type": [
            "string",
            "null"
          ]
        },
        "volume": {
          "type": [
            "string",
            "null"
          ]
        },
        "pages": {
          "type": [
            "string",
            "null"
          ]
        },
        "doi": {
          "type": [
            "string",
            "null"
          ]
        },
        "pmid": {
          "type": [
            "string",
            "null"
          ]
        },
        "url": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        }
      }
    },
    "data_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "collection"
      ],
      "properties": {
        "collection": {
          "type": "string",
          "minLength": 1
        },
        "tables": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "purpose": {
          "type": [
            "string",
            "null"
          ]
        },
        "reference": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "cross_project_dep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project",
        "relationship"
      ],
      "properties": {
        "project": {
          "type": "string",
          "minLength": 1
        },
        "relationship": {
          "type": "string",
          "enum": [
            "data_input",
            "extends",
            "contradicts",
            "replicates",
            "synthesizes"
          ]
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "notebook": {
          "type": [
            "string",
            "null"
          ]
        },
        "figures": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "data_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "references": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "statistics": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "boolean",
              "null"
            ]
          }
        }
      }
    },
    "generated_data_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "file"
      ],
      "properties": {
        "file": {
          "type": "string",
          "minLength": 1
        },
        "rows": {
          "type": [
            "integer",
            "null"
          ]
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_notebook": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
