{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FCD7YYYhdzPGLe2bVFHQD5","type":"tool_result","content":"560\t\n561\tdef _check_data_figure(content: dict, path: str) -> list[ValidatorIssue]:\n562\t    iss: list[ValidatorIssue] = []\n563\t    _check_required_str(content, \"title\", path, iss)\n564\t    _check_required_str(content, \"figure\", path, iss)\n565\t    _check_required_str(content, \"caption\", path, iss)\n566\t    _check_optional_str(content, \"data_source\", path, iss)\n567\t    _check_figure_path(content, \"figure\", path, iss)\n568\t    # Caption length cap (v0.3.5): see DATA_FIGURE_CAPTION_MAX_CHARS\n569\t    # docstring above for the live-failure motivation.\n570\t    cap = content.get(\"caption\")\n571\t    if isinstance(cap, str) and len(cap) > DATA_FIGURE_CAPTION_MAX_CHARS:\n572\t        # M6 Tier C.1 (D-068): soft-warning, not hard error. The\n573\t        # renderer's MSO_AUTO_SIZE.TEXT_TO_FIT_SHAPE in\n574\t        # assemble_pptx._fill_data_figure is the load-bearing\n575\t        # protection against brand-strip overflow now; this validator\n576\t        # is advisory (matching the M4a Tier B / DQ4 posture for the\n577\t        # other 4 length caps). Pre-2026-05-25 this was severity=\"error\"\n578\t        # — see DATA_FIGURE_CAPTION_MAX_CHARS docstring for the\n579\t        # demote rationale.\n580\t        iss.append(ValidatorIssue(\n581\t            f\"{path}.caption\",\n582\t            f\"data_figure caption is {len(cap)} chars; advisory cap \"\n583\t            f\"{DATA_FIGURE_CAPTION_MAX_CHARS} (overflow risks running into \"\n584\t            f\"the brand strip at y=5.00; renderer shrink-to-fit absorbs). \"\n585\t            f\"Move citations to data_source, drop redundant phrasing, \"\n586\t            f\"or split insight across multiple slides for readability. \"\n587\t            f\"See slide_compose.v1.md / revise_slide.v1.md.\",\n588\t            severity=\"soft-warning\",\n589\t        ))\n590\t    return iss\n591\t\n592\t\n593\t# v0.3.2: data_table layout — ranked top-N, comparison matrices, etc.\n594\tDATA_TABLE_MAX_ROWS = 12\n595\tDATA_TABLE_MAX_COLS = 6\n596\t\n597\t\n598\tdef _check_data_table(content: dict, path: str) -> list[ValidatorIssue]:\n599\t    \"\"\"Validate a data_table content block.\n600\t\n601\t    Schema:\n602\t      title:            required str\n603\t      columns:          required list[str], 2 ≤ len ≤ DATA_TABLE_MAX_COLS,\n604\t                        non-empty header strings\n605\t      rows:             required list[list[str]], 1 ≤ len ≤ DATA_TABLE_MAX_ROWS,\n606\t                        each inner list has len(columns) cells, ALL strings\n607\t                        (caller must stringify numbers with desired precision)\n608\t      caption:          optional str (~1 sentence; rendered below table)\n609\t      footnote:         optional str (~1 line; rendered at slide-bottom)\n610\t      data_source:      optional str (REPORT.md §X.Y or notebook reference)\n611\t      highlight_rows:   optional list[int], indices of rows to render in\n612\t                        the KBase-orange highlight band (0-based, must\n613\t                        all be < len(rows))\n614\t    \"\"\"\n615\t    iss: list[ValidatorIssue] = []\n616\t    _check_required_str(content, \"title\", path, iss)\n617\t\n618\t    # columns — list of 2-6 strings. Empty-string headers ARE allowed\n619\t    # (matrix-table convention: the corner cell where row labels meet\n620\t    # column labels is conventionally empty, e.g.\n621\t    # `[\"\", \"Conserved\", \"Variable\"]` for a quadrant classification).\n622\t    # v0.3.2.2: relaxed from \"non-empty header strings\" — the v0.3.2\n623\t    # worked example in slide_compose.v1.md uses this exact pattern,\n624\t    # and the LLM faithfully reproduced it (caught in core_gene_tradeoffs\n625\t    # draft_2 selection-signature-matrix slide).\n626\t    cols = content.get(\"columns\")\n627\t    if cols is None:\n628\t        iss.append(ValidatorIssue(f\"{path}.columns\", \"required field missing\"))\n629\t        cols = []\n630\t    elif not isinstance(cols, list):\n631\t        iss.append(ValidatorIssue(\n632\t            f\"{path}.columns\",\n633\t            \"must be a list of 2-6 header strings\",\n634\t        ))\n635\t        cols = []\n636\t    elif len(cols) < 2:\n637\t        iss.append(ValidatorIssue(\n638\t            f\"{path}.columns\",\n639\t            f\"must have at least 2 columns; got {len(cols)} \""}]},"parent_tool_use_id":null,"session_id":"ba2d6b0f-241e-4c07-96a3-a6effebadbb7","uuid":"b50c4661-936a-4574-8d18-e58f1be5d694","timestamp":"2026-06-07T16:47:47.203Z","tool_use_result":{"type":"text","file":{"filePath":"/home/aparkin/BERIL-research-observatory/.claude/skills/beril-presentation-maker/tools/slide_spec.py","content":"\ndef _check_data_figure(content: dict, path: str) -> list[ValidatorIssue]:\n    iss: list[ValidatorIssue] = []\n    _check_required_str(content, \"title\", path, iss)\n    _check_required_str(content, \"figure\", path, iss)\n    _check_required_str(content, \"caption\", path, iss)\n    _check_optional_str(content, \"data_source\", path, iss)\n    _check_figure_path(content, \"figure\", path, iss)\n    # Caption length cap (v0.3.5): see DATA_FIGURE_CAPTION_MAX_CHARS\n    # docstring above for the live-failure motivation.\n    cap = content.get(\"caption\")\n    if isinstance(cap, str) and len(cap) > DATA_FIGURE_CAPTION_MAX_CHARS:\n        # M6 Tier C.1 (D-068): soft-warning, not hard error. The\n        # renderer's MSO_AUTO_SIZE.TEXT_TO_FIT_SHAPE in\n        # assemble_pptx._fill_data_figure is the load-bearing\n        # protection against brand-strip overflow now; this validator\n        # is advisory (matching the M4a Tier B / DQ4 posture for the\n        # other 4 length caps). Pre-2026-05-25 this was severity=\"error\"\n        # — see DATA_FIGURE_CAPTION_MAX_CHARS docstring for the\n        # demote rationale.\n        iss.append(ValidatorIssue(\n            f\"{path}.caption\",\n            f\"data_figure caption is {len(cap)} chars; advisory cap \"\n            f\"{DATA_FIGURE_CAPTION_MAX_CHARS} (overflow risks running into \"\n            f\"the brand strip at y=5.00; renderer shrink-to-fit absorbs). \"\n            f\"Move citations to data_source, drop redundant phrasing, \"\n            f\"or split insight across multiple slides for readability. \"\n            f\"See slide_compose.v1.md / revise_slide.v1.md.\",\n            severity=\"soft-warning\",\n        ))\n    return iss\n\n\n# v0.3.2: data_table layout — ranked top-N, comparison matrices, etc.\nDATA_TABLE_MAX_ROWS = 12\nDATA_TABLE_MAX_COLS = 6\n\n\ndef _check_data_table(content: dict, path: str) -> list[ValidatorIssue]:\n    \"\"\"Validate a data_table content block.\n\n    Schema:\n      title:            required str\n      columns:          required list[str], 2 ≤ len ≤ DATA_TABLE_MAX_COLS,\n                        non-empty header strings\n      rows:             required list[list[str]], 1 ≤ len ≤ DATA_TABLE_MAX_ROWS,\n                        each inner list has len(columns) cells, ALL strings\n                        (caller must stringify numbers with desired precision)\n      caption:          optional str (~1 sentence; rendered below table)\n      footnote:         optional str (~1 line; rendered at slide-bottom)\n      data_source:      optional str (REPORT.md §X.Y or notebook reference)\n      highlight_rows:   optional list[int], indices of rows to render in\n                        the KBase-orange highlight band (0-based, must\n                        all be < len(rows))\n    \"\"\"\n    iss: list[ValidatorIssue] = []\n    _check_required_str(content, \"title\", path, iss)\n\n    # columns — list of 2-6 strings. Empty-string headers ARE allowed\n    # (matrix-table convention: the corner cell where row labels meet\n    # column labels is conventionally empty, e.g.\n    # `[\"\", \"Conserved\", \"Variable\"]` for a quadrant classification).\n    # v0.3.2.2: relaxed from \"non-empty header strings\" — the v0.3.2\n    # worked example in slide_compose.v1.md uses this exact pattern,\n    # and the LLM faithfully reproduced it (caught in core_gene_tradeoffs\n    # draft_2 selection-signature-matrix slide).\n    cols = content.get(\"columns\")\n    if cols is None:\n        iss.append(ValidatorIssue(f\"{path}.columns\", \"required field missing\"))\n        cols = []\n    elif not isinstance(cols, list):\n        iss.append(ValidatorIssue(\n            f\"{path}.columns\",\n            \"must be a list of 2-6 header strings\",\n        ))\n        cols = []\n    elif len(cols) < 2:\n        iss.append(ValidatorIssue(\n            f\"{path}.columns\",\n            f\"must have at least 2 columns; got {len(cols)} \"","numLines":80,"startLine":560,"totalLines":1841}}}
