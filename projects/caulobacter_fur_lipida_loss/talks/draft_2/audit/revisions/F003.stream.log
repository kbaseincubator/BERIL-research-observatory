\": false,\n      \"is_preprint\": false,\n      \"notes\": \"IS-driven mechanism in clinical A. baumannii. Supports evidence map row 9 (alternative LPS-loss route without Fur).\",\n      \"bib_key\": \"Moffatt2011\"\n    },\n    {\n      \"authors\": [\n        \"van der Ley P\",\n        \"Steeghs L\"\n      ],\n      \"year\": 2003,\n      \"title\": \"Lessons from an LPS-deficient Neisseria meningitidis mutant\",\n      \"venue\": \"J Endotoxin Res 9(2):124-128\",\n      \"doi\": \"10.1179/096805103125001522\",\n      \"pmid\": \"12803887\",\n      \"pmcid\": null,\n      \"arxiv\": null,\n      \"biorxiv\": null,\n      \"studied\": \"N. meningitidis ΔlpxA; review of OM composition, immunogenicity, and inflammatory response\",\n      \"finding\": \"LPS-deficient N. meningitidis retains OMP assembly but has reduced iron-limitation-inducible lipoprotein expression and reduced OM protein immunogenicity. Capsule essential for viability without LPS.\",\n      \"scope_alignment\": \"partial\",\n      \"assessment\": \"supports\",\n      \"is_review_article\": true,\n      \"is_preprint\": false,\n      \"notes\": \"Companion review to Steeghs 2001. Notes reduced iron-limitation-inducible lipoproteins (oblique iron connection). Supports evidence map row 9.\",\n      \"bib_key\": \"Ley2003\"\n    },\n    {\n      \"authors\": [\n        \"Flynn JM\",\n        \"Levchenko I\",\n        \"Sauer RT\",\n        \"Baker TA\"\n      ],\n      \"year\": 2004,\n      \"title\": \"Modulating substrate choice: the SspB adaptor delivers a regulator of the extracytoplasmic-stress response to the AAA+ protease ClpXP for degradation\",\n      \"venue\": \"Genes Dev 18(18):2292-2301\",\n      \"doi\": \"10.1101/gad.1240104\",\n      \"pmid\": \"15371343\",\n      \"pmcid\": \"PMC517522\",\n      \"arxiv\": null,\n      \"biorxiv\": null,\n      \"studied\": \"E. coli; SspB adaptor, ClpXP protease, RseA anti-sigma-E factor; trapping + biochemical + genetic studies\",\n      \"finding\