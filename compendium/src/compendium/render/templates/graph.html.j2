<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Compendium — Graph</title>
  <style>
    body { font-family: system-ui, sans-serif; margin: 0; }
    nav { padding: 0.75rem 1rem; border-bottom: 1px solid #d0d7de; }
    a { color: #1366d6; }
    #cy { width: 100%; height: 85vh; }
  </style>
  <script src="{{ cytoscape_cdn }}"></script>
</head>
<body>
  <nav><a href="index.html">index</a></nav>
  <div id="cy"></div>
  <script>
    const GRAPH = {{ graph_json | safe }};
    const cy = cytoscape({
      container: document.getElementById('cy'),
      elements: { nodes: GRAPH.nodes, edges: GRAPH.edges },
      layout: { name: 'preset' },
      style: [
        { selector: 'node', style: { 'label': 'data(label)', 'font-size': '8px' } },
        { selector: 'edge', style: { 'label': 'data(label)', 'curve-style': 'bezier',
          'target-arrow-shape': 'triangle', 'font-size': '6px' } }
      ]
    });
  </script>
</body>
</html>
