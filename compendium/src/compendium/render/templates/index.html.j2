<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Compendium</title>
  <style>
    body { font-family: system-ui, sans-serif; margin: 2rem auto; max-width: 64rem; padding: 0 1rem; color: #1a1a1a; }
    a { color: #1366d6; }
    .badge { display: inline-block; padding: 0.1rem 0.5rem; border-radius: 0.5rem; font-size: 0.8rem; color: #fff; }
    .badge.green { background: #1a7f37; }
    .badge.amber { background: #bf8700; }
    .badge.red { background: #cf222e; }
    .muted { color: #57606a; font-size: 0.85rem; }
    table { border-collapse: collapse; width: 100%; }
    th, td { border: 1px solid #d0d7de; padding: 0.4rem 0.6rem; text-align: left; }
  </style>
</head>
<body>
  <h1>Compendium</h1>
  <p class="muted"><a href="graph.html">graph view</a></p>

  <h2>Counts</h2>
  <p>{{ node_count }} nodes &middot; {{ edge_count }} edges</p>

  <h2>Tier distribution</h2>
  <ul>
    {% for t in tier_dist %}
      <li><span class="badge {{ t.badge.color }}">{{ t.badge.label }}</span> {{ t.count }}</li>
    {% endfor %}
  </ul>

  <h2>Pages</h2>
  <table>
    <thead><tr><th>label</th><th>type</th><th>tier</th></tr></thead>
    <tbody>
    {% for e in entries %}
      <tr>
        <td><a href="wiki/{{ e.slug }}.html">{{ e.label }}</a></td>
        <td>{{ e.type }}</td>
        <td><span class="badge {{ e.badge.color }}">{{ e.badge.label }}</span></td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
</body>
</html>
