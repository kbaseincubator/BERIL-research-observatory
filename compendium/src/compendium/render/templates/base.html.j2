<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{% block title %}Compendium{% endblock %}</title>
  <style>
    body { font-family: system-ui, sans-serif; margin: 2rem auto; max-width: 64rem; padding: 0 1rem; color: #1a1a1a; }
    a { color: #1366d6; }
    .badge { display: inline-block; padding: 0.1rem 0.5rem; border-radius: 0.5rem; font-size: 0.8rem; color: #fff; }
    .badge.green { background: #1a7f37; }
    .badge.amber { background: #bf8700; }
    .badge.red { background: #cf222e; }
    .badge.tier { color: #fff; }
    table { border-collapse: collapse; width: 100%; }
    th, td { border: 1px solid #d0d7de; padding: 0.4rem 0.6rem; text-align: left; }
    code { background: #f6f8fa; padding: 0.1rem 0.3rem; border-radius: 0.3rem; }
    .muted { color: #57606a; font-size: 0.85rem; }
    .mermaid { background: #f6f8fa; padding: 1rem; border-radius: 0.5rem; }
  </style>
  {% block head %}{% endblock %}
</head>
<body>
  <nav class="muted"><a href="../index.html">index</a> &middot; <a href="../graph.html">graph</a></nav>
  {% block body %}{% endblock %}
</body>
</html>
