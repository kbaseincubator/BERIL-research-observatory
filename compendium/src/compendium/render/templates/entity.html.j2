{% extends "base.html.j2" %}
{% block title %}{{ node.label }}{% endblock %}
{% block head %}
  <script src="{{ mermaid_cdn }}"></script>
  <script>mermaid.initialize({ startOnLoad: true });</script>
{% endblock %}
{% block body %}
  <h1>{{ node.label }} <span class="badge {{ badge.color }} tier">{{ badge.label }}</span></h1>
  <p class="muted">
    type: <code>{{ node.type }}</code>
    {% if node.curie %}&middot; curie: <code>{{ node.curie }}</code>{% endif %}
    &middot; id: <code>{{ node.id }}</code>
  </p>

  <h2>Facts</h2>
  {% if facts %}
  <table>
    <thead><tr><th>predicate</th><th>neighbor</th><th>tier</th><th>provenance</th></tr></thead>
    <tbody>
    {% for f in facts %}
      <tr>
        <td>{{ f.predicate }}{% if f.direction == "in" %} (incoming){% endif %}</td>
        <td>{% if f.neighbor_safe %}<a href="{{ f.neighbor_safe }}.html">{{ f.neighbor_label }}</a>{% else %}{{ f.neighbor_label }}{% endif %}</td>
        <td><span class="badge {{ f.badge.color }} tier">{{ f.badge.label }}</span></td>
        <td class="muted">{{ f.provenance | join(", ") }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% else %}
  <p class="muted">No facts.</p>
  {% endif %}

  <h2>Graph</h2>
  <pre class="mermaid">{{ mermaid }}</pre>

  {% if narration %}
  <h2>Synthesis</h2>
  <p>{{ narration }}</p>
  {% endif %}

  <h2>Provenance</h2>
  <p class="muted">projects: {{ node.provenance | join(", ") if node.provenance else "(none)" }}</p>
  <p class="muted">fact hash: <code>{{ fact_hash }}</code></p>
{% endblock %}
