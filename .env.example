KBASE_AUTH_TOKEN=YOUR_AUTH_TOKEN_HERE

# ORCiD OAuth2 (register at https://orcid.org/developer-tools)
# Use https://sandbox.orcid.org for development/testing
BERIL_ORCID_BASE_URL=https://sandbox.orcid.org
BERIL_ORCID_CLIENT_ID=APP-XXXXXXXXXXXXXXXX
BERIL_ORCID_CLIENT_SECRET=your-orcid-client-secret  # provided by ORCiD
BERIL_ORCID_REDIRECT_ROOT=http://127.0.0.1:8000  # use 127.0.0.1 not localhost — ORCiD blocks localhost
BERIL_ORCID_REDIRECT_PATH=/auth/orcid/callback  # path to the callback route, relative to root

# Auth token providers
# In addition to the ORCiD login, other auth providers can be made available
# These should be listed here, and the names should match those given by modules
# in the ui/app/auth_providers directory
BERIL_AUTH_TOKEN_PROVIDERS=kbase


# Session secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
BERIL_SESSION_SECRET_KEY=change-me-in-production

# Lakehouse data source — picks which LakehouseSource implementation
# materializes the projects/ tree on startup and on the data-update webhook.
# "git" (default) clones the legacy data-cache branch; "berdl" reads MinIO.
BERIL_LAKEHOUSE_SOURCE=git

# Where the active lakehouse source stages downloaded content. Mount a
# persistent volume here in production so a restart doesn't re-download.
BERIL_LAKEHOUSE_CACHE_DIR=/tmp/beril_lakehouse_cache

# BERDL MinIO settings (only used when BERIL_LAKEHOUSE_SOURCE=berdl).
# Access/secret are a service-account pair — from Rancher secret in prod,
# from .env locally. Both required when the source is active.
BERIL_BERDL_MINIO_ENDPOINT=https://minio.berdl.kbase.us
BERIL_BERDL_MINIO_ACCESS_KEY=
BERIL_BERDL_MINIO_SECRET_KEY=
BERIL_BERDL_MINIO_BUCKET=cdm-lake
# Public archive path the submit skill writes to; trailing slash is required.
BERIL_BERDL_PROJECTS_PREFIX=tenant-general-warehouse/microbialdiscoveryforge/projects/
# Optional HTTPS proxy for off-cluster dev (e.g. docker-compose). Leave unset
# in prod on beril.kbase.us — direct MinIO connectivity is available there.
# BERIL_BERDL_HTTPS_PROXY=http://host.docker.internal:8123
# S3 addressing style. "path" works for MinIO today and Ceph RadosGW after
# migration; "virtual" is AWS-S3's default. Leave as "path" unless you hit a
# backend that demands virtual-hosted-style URLs.
BERIL_BERDL_S3_ADDRESSING_STYLE=path

# PostgreSQL database — run `alembic upgrade head` before first start
# Format: postgresql+asyncpg://DB_USER:DB_PASSWORD@DB_HOST:DB_PORT/DB_NAME
# Alter the below
BERIL_DB_URL=postgresql+asyncpg://beril:beril@localhost:5432/beril
BERIL_DB_HOST=localhost  # change this to the exposed service name in SPIN
BERIL_DB_PORT=5432
BERIL_DB_USER=beril_user
BERIL_DB_PASSWORD=change-in-production
BERIL_DB_NAME=beril
